# Void Drift — environment configuration
# Copy to /etc/voidrift/voidrift.env and set permissions: chmod 600 voidrift.env
#
# All variables are optional; compiled-in defaults are shown below.
# Command-line flags always override these values.

# IRC server (host:port)
#VOIDRIFT_SERVER=irc.libera.chat:6667

# Bot nick
#VOIDRIFT_NICK=VoidKeeper

# Game channel
#VOIDRIFT_CHANNEL=#voidrift

# Server password (leave unset if not required)
#VOIDRIFT_PASSWORD=

# NickServ password — sent as IDENTIFY on connect (leave unset if not required)
#VOIDRIFT_NICKSERV=

# Use SSL/TLS (true or false)
#VOIDRIFT_SSL=false

# Data file paths (relative to working directory / chroot root)
#VOIDRIFT_DATA=voidrift.json
#VOIDRIFT_GUILDS=guilds.json

# Dev mode: auto-login channel members on startup, speed up TTL 5× (true or false)
#VOIDRIFT_DEV=false

# Event rate multipliers (1.0 = normal; higher = more frequent)
#VOIDRIFT_RATE_PLAYER=1.0
#VOIDRIFT_RATE_ALIGN=1.0
#VOIDRIFT_RATE_SERVER=1.0
